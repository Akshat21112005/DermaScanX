# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ──────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment / secrets ─────────────────────────────────────────
.env
!.env.example

# ── Model artifacts (large binary files) ─────────────────────────
artifacts/*.pkl
artifacts/*.pth
artifacts/*.pt
artifacts/*.bin
artifacts/*.onnx
# Keep the README and class_labels.json (small text files)
!artifacts/README.md
!artifacts/class_labels.json

# ── Logs ──────────────────────────────────────────────────────────
logs/
*.log

# ── IDE / OS ──────────────────────────────────────────────────────
.idea/
.vscode/
*.DS_Store
Thumbs.db
